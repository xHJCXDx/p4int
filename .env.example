# === Base de datos ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=p4intg_db
RUN_SEED_ON_STARTUP=false

# === Backend ===
SECRET_KEY=super-secret-dev-key

# === Frontend (UNA sola URL — para redirects de MercadoPago) ===
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:5173

# === MercadoPago ===
# Token privado de MercadoPago (formato APP_USR-...)
MP_ACCESS_TOKEN=

# Secreto opcional para validar webhooks (si se configura en MercadoPago) o URL de webhook
MP_WEBHOOK_SECRET=

# === Cloudinary (opcional) ===
# Si estas variables estan completas, las imagenes se suben a Cloudinary.
# Si quedan vacias, el sistema guarda imagenes localmente en backend/img.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# === ngrok (dominio fijo) ===
# Token y dominio solo necesarios si se usa el servicio ngrok del docker-compose.
NGROK_AUTHTOKEN=
NGROK_DOMAIN=

# === pgAdmin ===
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=1234
