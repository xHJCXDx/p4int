# ============================================================
# Variables de entorno — p4int Food Store
# Copiar a .env y completar los valores reales
# ============================================================

# -- Base de datos (PostgreSQL) --
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=p4int_db
DB_PORT=5432

# -- Backend --
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/p4int_db
SECRET_KEY=cambiar-esto-a-una-clave-segura-de-32-chars-minimo
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# -- Cloudinary (upload de imagenes) --
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# -- MercadoPago (Checkout Pro) --
# Access token: https://www.mercadopago.com.ar/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=TEST-tu-access-token-aca

# Webhook URL — en desarrollo local usar ngrok:
#   1. Instalar ngrok: https://ngrok.com/download
#   2. Ejecutar: ngrok http 8000
#   3. Copiar la URL https y agregar /api/v1/pagos/webhook
MERCADOPAGO_WEBHOOK_URL=https://TU-SUBDOMINIO.ngrok-free.app/api/v1/pagos/webhook

# Secret para validar firma de webhooks (opcional, configurar en panel MP)
MERCADOPAGO_WEBHOOK_SECRET=

FRONTEND_URL=http://localhost:5173

# -- Docker Compose (puertos) --
API_PORT=8000
