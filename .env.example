# ============================================================
# Variables de entorno — p4int Food Store
# Copiar a .env y completar los valores reales
# ============================================================

# -- Base de datos (PostgreSQL) --
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=p4int_db
DB_PORT=5432

# -- Backend --
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/p4int_db
SECRET_KEY=cambiar-esto-a-una-clave-segura-de-32-chars-minimo
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# -- Cloudinary (upload de imagenes) --
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# -- MercadoPago (Checkout Pro) --
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_URL=https://tu-dominio.com/api/v1/pagos/webhook
FRONTEND_URL=http://localhost:5173

# -- Docker Compose (puertos) --
API_PORT=8000
